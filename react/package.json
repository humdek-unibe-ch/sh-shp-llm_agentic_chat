{
  "name": "agentic-chat-react",
  "version": "1.0.0",
  "description": "React UMD bundles for the SelfHelp LLM Agentic Chat plugin (chat surface + admin module)",
  "main": "dist/agentic-chat.umd.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && vite build --config vite.admin.config.ts && vite build --config vite.threads.config.ts && node move-css.cjs",
    "build:chat": "tsc && vite build",
    "build:admin": "tsc && vite build --config vite.admin.config.ts",
    "build:threads": "tsc && vite build --config vite.threads.config.ts",
    "preview": "vite preview",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bootstrap": "^4.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "terser": "^5.27.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "author": "SelfHelp Team",
  "license": "MPL-2.0"
}
